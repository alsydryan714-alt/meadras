# ─────────────────────────────────────────────────────────────────────────────
# مدراس — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env وأضف القيم الحقيقية
# لا ترفع ملف .env أبداً على GitHub
# ─────────────────────────────────────────────────────────────────────────────

# ── قاعدة البيانات (إلزامي) ───────────────────────────────────────────────────
# رابط PostgreSQL — من قاعدة Render PostgreSQL أو أي مزود خارجي
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── المصادقة (إلزامي) ────────────────────────────────────────────────────────
# مفتاح سري لتوقيع JWT — يجب أن يكون طويلاً وعشوائياً ولا يتغير بين الإعادات
# لتوليد مفتاح: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ── الخادم (إلزامي في production) ────────────────────────────────────────────
# يُضبط تلقائياً بواسطة Render/منصة الاستضافة — لا تحتاج لضبطه يدوياً
PORT=3001
NODE_ENV=production

# ── CORS — عنوان الواجهة الأمامية (اختياري في Render all-in-one) ────────────
# أضفه إذا كانت الواجهة الأمامية على Vercel منفصلة
# FRONTEND_URL=https://your-app.vercel.app

# ── بوابة الدفع Moyasar (اختياري) ────────────────────────────────────────────
# المفتاح السري — للـ Backend فقط، لا يُشارك مع الـ Frontend
# MOYASAR_SECRET_KEY=sk_live_...

# المفتاح العام — يُرسل للـ Frontend عبر /api/payment/config
# MOYASAR_PUBLISHABLE_KEY=pk_live_...
